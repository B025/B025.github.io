# Copy this file to .env.local and fill in values from your Supabase project.
# Supabase Dashboard → Project Settings → API.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret — NEVER expose to the browser. Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The single email allowed into /members and /admin.
OWNER_EMAIL=bacak@eg.dk
